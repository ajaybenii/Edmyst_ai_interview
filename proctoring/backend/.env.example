# Proctoring — copy to .env (gitignored)

MONGO_URI=mongodb://USER:PASS@your-docdb.cluster.region.docdb.amazonaws.com:27017/?authMechanism=DEFAULT&tls=true&tlsCAFile=/path/to/global-bundle.pem&tlsAllowInvalidCertificates=true&tlsAllowInvalidHostnames=true&retryWrites=false
MONGODB_DB_NAME=Dev

PROCTORING_API_KEY=change-me-in-production
JWT_SECRET=change-me-in-production-min-32-chars
CORS_ORIGINS=*

# Same Function URL as AI interview Backend (GET user_id + video_token → assessment_result_id).
# When set, POST /v1/sessions calls Lambda first, then loads assessment_results by _id (Mongo still stores proctoring).
# Set empty or PROCTORING_USE_LAMBDA_SESSION_LOOKUP=false to resolve only by video_token on the document.
LAMBDA_SESSION_URL=
PROCTORING_USE_LAMBDA_SESSION_LOOKUP=true

# MONGODB_COLLECTION_ASSESSMENT_RESULTS=assessment_results
# VIDEO_TOKEN_FIELD=video_token
# MONGODB_COLLECTION_DASHBOARD_USERS=proctor_dashboard_users
# ALLOW_DASHBOARD_REGISTER=true
