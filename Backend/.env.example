# Copy to .env and adjust. Used by backend + optional frontend config generator.
# Google / AWS / Lambda vars — apni keys yahan add karo (README dekho).

# Public URLs (browser se API / WebSocket ke liye)
PUBLIC_API_BASE=https://edmyst-ai-interview.onrender.com
# Optional — agar khali chhodo to PUBLIC_API_BASE se auto: wss://.../ws/interview
PUBLIC_WS_URL=

# Proctoring API (proctoring/backend) — interview app events + dashboard
PROCTORING_API_BASE=http://127.0.0.1:8010
PROCTORING_API_KEY=dev-proctoring-key
