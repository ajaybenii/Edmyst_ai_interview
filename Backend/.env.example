# Google / Vertex (Live + STT)
GOOGLE_APPLICATION_CREDENTIALS=
# or GOOGLE_CREDENTIALS_JSON=
PROJECT_ID=sqy-prod
LOCATION=us-central1

# Lambda session lookup
LAMBDA_SESSION_URL=

# S3 uploads (mic / combined / rrweb + transcript JSON under ai_video_to_audio_nterview/)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=edy-temp-videos

# Tavus-style screen recording (Step Function: list tavus/{conversation_id}/)
TAVUS_RECORDINGS_BUCKET=edy-tavus
# Optional if Lambda session JSON does not include conversation_id yet:
# CONVERSATION_RESOLVE_URL=https://your-api/internal/assessment_result/conversation

# MongoDB — optional; if unset, transcript is only written to S3
MONGODB_URI=
MONGODB_DATABASE=edy
MONGODB_COLLECTION=assessment_results
# Add {"video_token": ...} to $or when matching documents (if your schema uses it)
MONGODB_MATCH_VIDEO_TOKEN=false

# Edy — candidate assessment completion (proxy from Netlify player → execute-api)
# Example: https://n0bkblehkh.execute-api.us-east-1.amazonaws.com/Prod
EDY_CANDIDATE_API_BASE=

# App
APP_ENV=Dev
LOG_LEVEL=INFO
MAX_CONCURRENT_CONNECTIONS=1000
CONNECTION_TIMEOUT=1800
